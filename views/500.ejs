<%- include('./partials/header', { title: '500 - Server Error' }) %>

<div style="text-align: center; margin: 3rem 0;">
  <h2 style="font-size: 3rem; color: #dc3545;">500</h2>
  <h3>Server Error</h3>
  <p style="font-size: 1.1rem; margin: 1rem 0; color: #666;">
    Something went wrong on our end. We're working to fix it.
  </p>
  
  <% if (typeof error !== 'undefined' && error) { %>
    <div style="background-color: #f8d7da; border: 1px solid #f5c6cb; color: #721c24; padding: 1rem; border-radius: 4px; margin: 2rem 0; max-width: 600px; margin-left: auto; margin-right: auto; text-align: left;">
      <strong>Error Details:</strong>
      <p><%= error %></p>
    </div>
  <% } %>
  
  <div style="margin-top: 2rem;">
    <a href="/" class="btn">Go Home</a>
    <a href="/products" class="btn" style="margin-left: 1rem; background-color: #6c757d;">Browse Products</a>
  </div>
</div>

<%- include('./partials/footer') %>
