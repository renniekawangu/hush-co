<%- include('../partials/header', { title: 'Admin Dashboard' }) %>

<h2>Admin Dashboard</h2>

<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 2rem; margin: 2rem 0;">
  <div style="background-color: #007bff; color: white; padding: 2rem; border-radius: 5px; text-align: center;">
    <h3>Products</h3>
    <p style="font-size: 2rem; margin: 1rem 0;">-</p>
    <a href="/admin/products" style="color: white; text-decoration: underline;">Manage Products</a>
  </div>

  <div style="background-color: #28a745; color: white; padding: 2rem; border-radius: 5px; text-align: center;">
    <h3>Users</h3>
    <p style="font-size: 2rem; margin: 1rem 0;">-</p>
    <a href="/admin/users" style="color: white; text-decoration: underline;">Manage Users</a>
  </div>

  <div style="background-color: #ffc107; color: #333; padding: 2rem; border-radius: 5px; text-align: center;">
    <h3>Orders</h3>
    <p style="font-size: 2rem; margin: 1rem 0;">-</p>
    <a href="/admin/orders" style="color: #333; text-decoration: underline;">View Orders</a>
  </div>

  <div style="background-color: #dc3545; color: white; padding: 2rem; border-radius: 5px; text-align: center;">
    <h3>Messages</h3>
    <p style="font-size: 2rem; margin: 1rem 0;">-</p>
    <a href="/admin/messages" style="color: white; text-decoration: underline;">View Messages</a>
  </div>
</div>

<%- include('../partials/footer') %>
