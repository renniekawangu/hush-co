<%- include('./partials/header', { title: 'Products' }) %>

<h2>Products</h2>

<div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 2rem; margin: 2rem 0;">
  <% if (products && products.length > 0) { %>
    <% products.forEach(product => { %>
      <div style="border: 1px solid #ddd; border-radius: 5px; padding: 1rem; background-color: white; box-shadow: 0 2px 5px rgba(0,0,0,0.1);">
        <h3><%= product.name %></h3>
        <p><%= product.description %></p>
        <p><strong>Price: $<%= product.price %></strong></p>
        <p>Stock: <%= product.stock %></p>
        <button class="btn" onclick="addToCart('<%= product._id %>')">Add to Cart</button>
      </div>
    <% }); %>
  <% } else { %>
    <p>No products available.</p>
  <% } %>
</div>

<script>
  function addToCart(productId) {
    fetch('/products/cart/add', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json'
      },
      body: JSON.stringify({ productId, quantity: 1 })
    })
    .then(response => response.json())
    .then(data => alert(data.message))
    .catch(error => console.error('Error:', error));
  }
</script>

<%- include('./partials/footer') %>
